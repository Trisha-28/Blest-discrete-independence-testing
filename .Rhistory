blest_discrete <- function(
support_x,
support_y,
joint_pmf,
px,
py,
Fx,
Fy
) {
total_sum <- 0
for (i in support_x) {
for (j in support_y) {
pij <- joint_pmf(i, j)
pi  <- px(i)
pj  <- py(j)
U_im1 <- Fx(i-1)
U_i   <- Fx(i)
V_jm1 <- Fy(j - 1)
V_j   <- Fy(j)
term1 <- (1 - U_im1)^2 + (1 - U_i)^2+((1 - U_im1)* (1 - U_i))
term2 <- V_j + V_jm1
total_sum <- total_sum +
(pij) * term1 * term2
}
}
blest <- 2 - 2 * total_sum
return(blest)
}
support_x <- 0:2
support_y <- 0:2
# Joint PMF (independent uniform case)
joint <- function(i, j) {
return(1/9)
}
# Marginals (not really needed, but included as per your function)
px <- function(i) {
return(1/3)
}
py <- function(j) {
return(1/3)
}
Fx <- function(i) {
if (i < 0) return(0)
if (i >= 2) return(1)
return((i + 1)/3)
}
Fy <- function(j) {
if (j < 0) return(0)
if (j >= 2) return(1)
return((j + 1)/3)
}
result <- blest_discrete(
support_x, support_y,
joint, px, py,
Fx, Fy
)
print(result)
