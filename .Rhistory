support_x <- 0:15
support_y <- 0:20
# Marginal PMFs
px <- function(i) dpois(i, lambda1)
py <- function(j) dpois(j, lambda2)
# Marginal CDFs
Fx <- function(i) if(i < 0) 0 else ppois(i, lambda1)
Fy <- function(j) if(j < 0) 0 else ppois(j, lambda2)
# Joint PMF assuming independence
joint_pmf <- function(i,j) px(i) * py(j)
# Compute BLEST
blest_value <- blest(support_x, support_y, joint_pmf, px, py, Fx, Fy)
lambda1 <- 3
lambda2 <- 5
# Marginal PMFs
px <- function(i) dpois(i, lambda1)
py <- function(j) dpois(j, lambda2)
# Marginal CDFs
Fx <- function(i) if(i < 0) 0 else ppois(i, lambda1)
Fy <- function(j) if(j < 0) 0 else ppois(j, lambda2)
# Joint PMF assuming independence
joint_pmf <- function(i,j) px(i) * py(j)
# Compute BLEST
blest_value <- blest(support_x, support_y, joint_pmf, px, py, Fx, Fy)
print(blest_value)
