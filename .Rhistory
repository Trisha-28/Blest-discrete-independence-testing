double_sum <- double_sum+(h*p_val*s_val)
}
}
bl<-2-(2*double_sum)
return(bl)
}
result <- nlminb(
start = 24,
objective = log_fun,
lower = 1e-8
)
estimates[r] <- result$par
kenestimate[r]<-kendall(estimates[r])
supestimate[r]<-spearman(estimates[r])
blestimate[r]<-blest(estimates[r])
results$mean_theta[j] <- mean(estimates)
results$sd_theta[j]   <- sd(estimates)
results$bias_theta[j] <- mean(estimates) - th_tr
results$rmse_theta[j] <- sqrt(mean((estimates - th_tr)^2))
results$mean_ken[j] <- mean(kenestimate)
results$sd_ken[j]   <- sd(kenestimate)
results$bias_ken[j] <- mean(kenestimate) - k_tr
results$rmse_ken[j] <- sqrt(mean((kenestimate - k_tr)^2))
results$mean_sup[j] <- mean(supestimate)
results$sd_sup[j]   <- sd(supestimate)
results$bias_sup[j] <- mean(supestimate) - s_tr
results$rmse_sup[j] <- sqrt(mean((supestimate - s_tr)^2))
results$mean_bl[j] <- mean(blestimate)
results$sd_bl[j]   <- sd(blestimate)
results$bias_bl[j] <- mean(blestimate) - b_tr
results$rmse_bl[j] <- sqrt(mean((blestimate - b_tr)^2))
}
}
results
library(copula)
library(bbmle)
N<-c(800)
results <- data.frame(
n = N,
mean_theta = NA, sd_theta = NA, bias_theta = NA, rmse_theta = NA,
mean_ken   = NA, sd_ken   = NA, bias_ken   = NA, rmse_ken   = NA,
mean_sup   = NA, sd_sup   = NA, bias_sup   = NA, rmse_sup   = NA,
mean_bl    = NA, sd_bl    = NA, bias_bl    = NA, rmse_bl    = NA
)
R<-1000
th_tr=20
estimates <- numeric(R)
kenestimate<-numeric(R)
supestimate<-numeric(R)
blestimate<-numeric(R)
copula_family <- "frank"
cop <- archmCopula(copula_family, param =th_tr)
kendall_t<-function(th){
double_sum <- 0
summ1<-0
summ2<-0
p=q=0.5
r1=r2=6
u<-70
v<-70
for (x in 0:u) {
for (y in 0:v) {
h <- cp(pnbinom(x,r1, p), pnbinom(y,r2, q), th) - cp(pnbinom(x - 1,r1, p), pnbinom(y,r2, q), th) - cp(pnbinom(x, r1,p), pnbinom(y - 1,r2, q), th) + cp(pnbinom(x - 1,r1, p), pnbinom(y - 1,r2, q), th)
p_val <- cp(pnbinom(x,r1, p), pnbinom(y,r2, q), th) +cp(pnbinom(x - 1,r1, p), pnbinom(y,r2, q), th) + cp(pnbinom(x,r1, p), pnbinom(y - 1,r2, q), th) + cp(pnbinom(x - 1,r1, p), pnbinom(y - 1,r2, q), th) - 1
double_sum <- double_sum+h*p_val
}
}
return(double_sum)
}
spearman_t <- function(th) {
double_sum <- 0
summ1<-0
summ2<-0
p=q=0.5
r1=r2=6
u<-70
v<-70
for (x in 0:u) {
for (y in 0:v) {
h <- cp(pnbinom(x,r1, p), pnbinom(y,r2, q), th) - cp(pnbinom(x - 1,r1, p), pnbinom(y,r2, q), th) - cp(pnbinom(x, r1,p), pnbinom(y - 1,r2, q), th) + cp(pnbinom(x - 1,r1, p), pnbinom(y - 1,r2, q), th)
p_val <- ((1-pnbinom(x,r1, p))*(1-pnbinom(y,r2, q)))+(pnbinom(x-1,r1,p)*pnbinom(y-1,r2,q))-(0.5*dnbinom(x,r1,p)*dnbinom(y,r2,q))
double_sum <- double_sum+h*p_val
}
}
for(x in 0:u){
summ1<-summ1+(dnbinom(x,r1,p))^2
}
for(y in 0:v){
summ2<-summ2+(dnbinom(y,r2,q))^2
}
sp<-(6*double_sum)+(3*summ1)+(3*summ2)-3
sp
return(sp)
}
blest_t <- function(th) {
double_sum <- 0
p=q=0.5
r1=r2=6
u<-70
v<-70
for (x in 0:u) {
for (y in 0:v) {
h <- cp(pnbinom(x,r1, p), pnbinom(y,r2, q), th) - cp(pnbinom(x - 1,r1, p), pnbinom(y,r2, q), th) - cp(pnbinom(x, r1,p), pnbinom(y - 1,r2, q), th) + cp(pnbinom(x - 1,r1, p), pnbinom(y - 1,r2, q), th)
t<-1-pnbinom(x-1,r1,p)
s<-1-pnbinom(x,r1,p)
p_val <-(t^2+s^2+(t*s))
s_val<-pnbinom(y-1,r2,q)+pnbinom(y,r2,q)
double_sum <- double_sum+(h*p_val*s_val)
}
}
bl<-2-(2*double_sum)
return(bl)
}
cp <- function(u, v, th) {
c <- ((exp(-th * u) - 1) * (exp(-th * v) - 1)) / (exp(-th) - 1)
d <- c + 1
cope <- -(1 / th) * log(d)
return(cope)
}
marg_probx<-function(a,x){
count <- 0
p<-length(x)
for (k in 1:p) {
if (x[k]==a) {
count <- count + 1
}
}
return(count/p)
}
marg_proby<-function(b,y){
count <- 0
p<-length(y)
for (k in 1:p) {
if (y[k]==b) {
count <- count + 1
}
}
return(count/p)
}
cdf_x <- function(a,x) {
cf1 <- ecdf(x)
return(cf1(a))
}
cdf_y <- function(b,y) {
cf2 <- ecdf(y)
return(cf2(b))
}
pdf_function <- function(x, y, th) {
cf1 <- ecdf(x1)
cf2<-  ecdf(x2)
return(cp(cf1(x), cf2(y), th) - cp(cf1(x - 1), cf2(y),th) - cp(cf1(x), cf2(y -1), th) + cp(cf1(x - 1), cf2(y - 1), th))
}
pdf_function_2 <- function(x, y, th) {
cf1 <- ecdf(x1)
cf2<-  ecdf(x2)
return(cp(cf1(x), cf2(y), th) +cp(cf1(x - 1), cf2(y),th) +cp(cf1(x), cf2(y -1), th) + cp(cf1(x - 1), cf2(y - 1), th))
}
k_tr<-kendall_t(th_tr)
s_tr<-spearman_t(th_tr)
b_tr<-blest_t(th_tr)
for (j in seq_along(N)) {
for(r in 1:R){
n<-N[j]
U <- rCopula(n,cop)
mu <- 0.5
size <- 6
u1 <- U[, 1]
u2 <- U[, 2]
x1 <- qnbinom(u1, size = size, prob = mu)
x2 <- qnbinom(u2, size = size, prob = mu)
u=max(x1)
v=max(x2)
data <- data.frame(X1 = x1, X2 = x2)
log_fun <- function(theta) {
sum=0
log_likelihood_values <- numeric(n)
for (i in 1:n) {
log_likelihood_values[i] <- log(pdf_function(data[i, 1], data[i, 2], theta))
sum=sum+log_likelihood_values[i]
}
return(-sum)
}
kendall<-function(th){
double_sum <- 0
summ1<-0
summ2<-0
for (x in 0:u) {
for (y in 0:v) {
h <- pdf_function(x,y,th)
p_val <- pdf_function_2(x,y,th)-1
double_sum <- double_sum+h*p_val
}
}
return(double_sum)
}
spearman <- function(th) {
double_sum <- 0
summ1<-0
summ2<-0
cf1 <- ecdf(x1)
cf2<-  ecdf(x2)
for (x in 0:u) {
for (y in 0:v) {
h <-  pdf_function(x,y,th)
p_val <- ((1-cf1(x))*(1-cf2(y)))+(cf1(x-1)*cf2(y-1))-(0.5*marg_probx(x,x1)*marg_proby(y,x2))
double_sum <- double_sum+h*p_val
}
}
for(x in 0:u){
summ1<-summ1+(marg_probx(x,x1))^2
}
for(y in 0:v){
summ2<-summ2+(marg_proby(y,x2))^2
}
sp<-(6*double_sum)+(3*summ1)+(3*summ2)-3
sp
return(sp)
}
blest <- function(th) {
double_sum <- 0
cf1 <- ecdf(x1)
cf2<-  ecdf(x2)
for (x in 0:u) {
for (y in 0:v) {
h <-  pdf_function(x,y,th)
t<-1-cf1(x-1)
s<-1-cf1(x)
p_val <-(t^2+s^2+(t*s))
s_val<-cf2(y-1)+cf2(y)
double_sum <- double_sum+(h*p_val*s_val)
}
}
bl<-2-(2*double_sum)
return(bl)
}
result <- nlminb(
start = 24,
objective = log_fun,
lower = 1e-8
)
estimates[r] <- result$par
kenestimate[r]<-kendall(estimates[r])
supestimate[r]<-spearman(estimates[r])
blestimate[r]<-blest(estimates[r])
results$mean_theta[j] <- mean(estimates)
results$sd_theta[j]   <- sd(estimates)
results$bias_theta[j] <- mean(estimates) - th_tr
results$rmse_theta[j] <- sqrt(mean((estimates - th_tr)^2))
results$mean_ken[j] <- mean(kenestimate)
results$sd_ken[j]   <- sd(kenestimate)
results$bias_ken[j] <- mean(kenestimate) - k_tr
results$rmse_ken[j] <- sqrt(mean((kenestimate - k_tr)^2))
results$mean_sup[j] <- mean(supestimate)
results$sd_sup[j]   <- sd(supestimate)
results$bias_sup[j] <- mean(supestimate) - s_tr
results$rmse_sup[j] <- sqrt(mean((supestimate - s_tr)^2))
results$mean_bl[j] <- mean(blestimate)
results$sd_bl[j]   <- sd(blestimate)
results$bias_bl[j] <- mean(blestimate) - b_tr
results$rmse_bl[j] <- sqrt(mean((blestimate - b_tr)^2))
}
}
results
